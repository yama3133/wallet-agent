# AWS
AWS_REGION=us-east-1
# aws login で取得した認証情報は ~/.aws/credentials に保存される想定。
# ここではプロファイル名を上書きしたい場合のみ指定。
# AWS_PROFILE=default

# Payment provider 選択: StripePrivy または CoinbaseCDP
PAYMENT_PROVIDER=StripePrivy

# --- StripePrivy を使う場合 ---
PRIVY_APP_ID=
PRIVY_APP_SECRET=
PRIVY_AUTHORIZATION_ID=
# 注意: wallet-auth: プレフィックスを取り除いた base64 のみ
PRIVY_AUTHORIZATION_PRIVATE_KEY=

# --- CoinbaseCDP を使う場合 ---
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=
CDP_WALLET_SECRET=

# テスト用エンドユーザー
TEST_USER_ID=test-user-yama3133
TEST_USER_EMAIL=fcl35924550909@gmail.com

# Payment session 設定
PAYMENT_SESSION_MAX_USD=1.00
PAYMENT_SESSION_EXPIRY_MINUTES=60

# テスト用 x402 マーチャント（例: Coinbase x402 Bazaar の test endpoint や、自前モックを指定）
TEST_MERCHANT_URL=https://drvd12nxpcyd5.cloudfront.net/market-recap

# --- Phase 2: 楽天市場API ---
# https://webservice.rakuten.co.jp/app/list で発行
RAKUTEN_APPLICATION_ID=
# RAKUTEN_AFFILIATE_ID=

# --- Phase 2: Stripe Checkout（テストモード）---
# https://dashboard.stripe.com/test/apikeys で取得（sk_test_...）
STRIPE_SECRET_KEY=

# 承認カード/checkout のSuccess/Cancel URL用（Vercelデプロイ後はpublic URLに）
WALLET_AGENT_PUBLIC_URL=http://localhost:3002

# --- DynamoDB（承認/タスクストア）---
# local = agent/.approvals.json, dynamo = wallet_agent_approvals テーブル
WALLET_AGENT_STORAGE=local
WALLET_AGENT_APPROVALS_TABLE=wallet_agent_approvals
WALLET_AGENT_TASKS_TABLE=wallet_agent_tasks
WALLET_AGENT_TXNS_TABLE=wallet_agent_txns
